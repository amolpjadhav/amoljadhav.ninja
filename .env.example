# Supabase — Settings > API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never expose to the client. Required for
# writes from API routes (contact form) and for the Medium migration script.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — used by /api/contact for email notifications (not yet wired up)
RESEND_API_KEY=
CONTACT_EMAIL=
